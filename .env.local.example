# Copia este archivo como .env.local y ajusta solo tu entorno local.
# Nunca coloques secretos de producción aquí.
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=designs_crm
ENABLE_DEMO_SEED=true
ENABLE_PUBLIC_SIGNUP=false
MUTATION_RATE_LIMIT=90
# En producción detrás de un único proxy HTTPS (Nginx/Apache/Cloudflare), usa 1.
# Déjalo vacío si Node recibe las conexiones directamente.
TRUST_PROXY_HOPS=
